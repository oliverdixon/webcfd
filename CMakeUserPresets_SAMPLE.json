{
  "version": 6,
  "configurePresets": [
    {
      "name": "vcpkg-local",
      "environment": {
        "VCPKG_ROOT": "/home/owd/vcpkg"
      }
    },
    {
      "name": "wasm-local",
      "environment": {
        "EMSDK": "/home/owd/Documents/emsdk",
        "EMSCRIPTEN_ROOT": "/home/owd/Documents/emsdk/upstream/emscripten",
        "PATH": "/home/owd/Documents/emsdk:/home/owd/Documents/emsdk/upstream/emscripten:$penv{PATH}"
      }
    },

    {
      "name": "native-debug-local",
      "hidden": false,
      "inherits": [
        "vcpkg-local",
        "native-debug"
      ]
    },
    {
      "name": "native-release-local",
      "hidden": false,
      "inherits": [
        "vcpkg-local",
        "native-release"
      ]
    },

    {
      "name": "wasm-debug-local",
      "hidden": false,
      "inherits": [
        "wasm-local",
        "wasm-debug",
        "vcpkg-local"
      ]
    },
    {
      "name": "wasm-release-local",
      "hidden": false,
      "inherits": [
        "wasm-local",
        "wasm-release",
        "vcpkg-local"
      ]
    }
  ]
}
