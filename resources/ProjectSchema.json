{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EchoMap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "signals",
    "sensors",
    "mappings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "modified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      },
      "uniqueItems": true
    },
    "sensors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sensor"
      },
      "uniqueItems": true
    },
    "mappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mapping"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "oneOf": [
            {
              "$ref": "#/$defs/embeddedUniform"
            },
            {
              "$ref": "#/$defs/embeddedVariable"
            },
            {
              "$ref": "#/$defs/filesystem"
            }
          ]
        }
      }
    },
    "embeddedUniform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sample_count",
        "time_offset",
        "sample_rate",
        "samples"
      ],
      "properties": {
        "kind": {
          "const": "embeddedUniform"
        },
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "time_offset": {
          "type": "number"
        },
        "sample_rate": {
          "type": "integer",
          "minimum": 0
        },
        "samples": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "embeddedVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sample_count",
        "samples"
      ],
      "properties": {
        "kind": {
          "const": "embeddedVariable"
        },
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "time_offset": {
          "type": "number"
        },
        "sample_rate": {
          "type": "integer",
          "minimum": 0
        },
        "samples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "time",
              "amplitude"
            ],
            "properties": {
              "time": {
                "type": "number"
              },
              "amplitude": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "channel"
      ],
      "properties": {
        "kind": {
          "const": "filesystem"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sensor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "position",
        "colour"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "colour": {
          "$ref": "#/$defs/rgba"
        }
      }
    },
    "vec3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "rgba": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "r",
        "g",
        "b",
        "a"
      ],
      "properties": {
        "r": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "g": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "b": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "a": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "sensor"
      ],
      "properties": {
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "sensor": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
